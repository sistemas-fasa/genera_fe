# Configuracion SMTP para envio de correos.
# Copiar este archivo como .env y completar los valores reales fuera de Git.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_TLS=1
SMTP_USER=usuario@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=usuario@example.com

# Notificacion automatica cuando se obtiene un CAEA nuevo.
CAEA_NOTIFICACION_EMAIL=sistemas@ferreteriaavenida.com.ar

# Contingencia CAEA para servidor central.
# "*" o sin configurar procesa todas las filas de fasa.imprefiscal de la empresa.
# Tambien se puede restringir con una lista: CAJA1,CAJA2,CAJA3.
MAQUINAS_IMPREFISCAL=*
# Compatibilidad legacy para instalaciones por caja. En servidor central,
# preferir MAQUINAS_IMPREFISCAL="*" o dejar el default todas.
# MAQUINA_IMPREFISCAL=CAJA1

# Compatibilidad con envios legacy por libs.Utiles.envia_correo.
FASA_ERROR_EMAIL_PASSWORD=change-me
